{
  "name": "zpd",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @zpd/app dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:e2e": "pnpm --filter @zpd/app test:e2e",
    "fonts:catalog": "node scripts/fetch-google-fonts-catalog.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "deploy": "wrangler deploy --env production",
    "deploy:dry": "wrangler deploy --dry-run --env production"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7",
    "wrangler": "^4.110.0"
  }
}
